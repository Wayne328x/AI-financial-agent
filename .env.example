# Environment Variables for AI Financial Agent

# Cohere API Key for embeddings and AI responses
COHERE_API_KEY=your_cohere_api_key_here

# Google API Key (if needed for additional services)
GOOGLE_API_KEY=your_google_api_key_here

# Database URL (use SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///./financial_db.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/financial_db